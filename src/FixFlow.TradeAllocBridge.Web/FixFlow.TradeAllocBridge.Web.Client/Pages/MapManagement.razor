    private Task ConfirmDeleteAsync(string clientId)
    {
        if (State.HasDeployedCopy)
        {
            ShowConfirm(
                "Delete Deployed Copy",
                $"A copy of the \"{clientId}\" map is deployed to the email automation service. Selecting OK will delete all copies (master and deployed). Proceed?",
                () => ExecuteDeleteAsync(clientId, deleteDeployed: true),
                () =>
                {
                    State.StatusMessage = "Delete cancelled";
                    return Task.CompletedTask;
                });
            return Task.CompletedTask;
        }

        return ExecuteDeleteAsync(clientId, deleteDeployed: false);
    }

    private async Task ExecuteDeleteAsync(string clientId, bool deleteDeployed)
    {
        _isBusy = true;
        try
        {
            State.StatusMessage = $"Deleting mapping: {clientId}...";
            var url = $"api/map-management/{Uri.EscapeDataString(clientId)}?deleteDeployed={deleteDeployed.ToString().ToLowerInvariant()}";
            var response = await Http.DeleteAsync(url);
            var payload = await response.Content.ReadAsStringAsync();
            MappingDeleteResponse? result = null;
            if (!string.IsNullOrWhiteSpace(payload))
            {
                try
                {
                    result = JsonSerializer.Deserialize<MappingDeleteResponse>(payload, new JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true
                    });
                }
                catch
                {
                    // fall through and rely on status code/message
                }
            }

            if (!response.IsSuccessStatusCode)
            {
                var details = result?.StatusMessage ?? payload ?? response.ReasonPhrase ?? "Delete failed.";
                State.StatusMessage = $"Delete failed ({(int)response.StatusCode}): {details}";
                return;
            }

            await LoadMappingsAsync(updateStatus: false);
            var stillExists = State.MappingOptions.Any(m =>
                string.Equals(m.ClientId, clientId, StringComparison.OrdinalIgnoreCase));

            if (stillExists && result?.Success == false)
            {
                State.StatusMessage = result.StatusMessage;
                return;
            }

            if (stillExists)
            {
                State.StatusMessage = result?.StatusMessage ?? "Delete failed: mapping still present.";
                return;
            }

            State.SelectedMapping = null;
            State.OriginalClientId = null;
            State.ClientId = string.Empty;
            State.OrganizationName = string.Empty;
            State.SenderDomain = string.Empty;
            State.DisableAllocationMerge = false;
            State.OnBehalfOfCompId = string.Empty;
            State.FieldMappings.Clear();
            State.IsEditing = false;
            State.HasUnsavedChanges = false;
            State.DateCreated = string.Empty;
            State.DateValidated = string.Empty;
            State.DateModified = string.Empty;
            State.EmailAutomationStatus = "Inactive";
            State.HasDeployedCopy = false;
            State.StatusMessage = result?.StatusMessage ?? $"Mapping deleted: {clientId}";
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Error deleting mapping: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeployMappingAsync()
    {
        if (string.IsNullOrWhiteSpace(State.SelectedMapping))
        {
            State.StatusMessage = "Please select a mapping to deploy";
            return;
        }

        _isBusy = true;
        try
        {
            var response = await Http.PostAsync($"api/map-management/{Uri.EscapeDataString(State.SelectedMapping)}/deploy", null);
            var result = await response.Content.ReadFromJsonAsync<MappingDeployResponse>();
            if (result is null)
            {
                State.StatusMessage = "Deploy failed.";
                return;
            }

            State.StatusMessage = result.StatusMessage;
            if (result.Success)
            {
                State.EmailAutomationStatus = result.EmailAutomationStatus ?? State.EmailAutomationStatus;
                State.HasDeployedCopy = true;
            }
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Failed to deploy mapping: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

