
@page "/map-management"
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject MapManagementState State
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Map Management</PageTitle>

<section class="page-header">
    <div>
        <h1>Map Management</h1>
        <p>Maintain client mappings, validate coverage, and stage mappings for automation.</p>
    </div>
</section>

<div class="map-layout">
    <section class="card map-sidebar">
        <div class="section-title">Client Mappings</div>
        <div class="map-list">
            @if (State.MappingOptions.Count == 0)
            {
                <div class="hint">No mappings found.</div>
            }
            else
            {
                @foreach (var option in State.MappingOptions)
                {
                    <button class="map-item @(IsSelected(option) ? "is-active" : string.Empty)" @onclick="() => SelectMappingAsync(option.ClientId)">
                        <div class="map-item-row">
                            <div class="map-item-title">@option.ClientId</div>
                            @if (option.IsValidated)
                            {
                                <span class="map-item-check"
                                      aria-label="Validated"
                                      title="@($"Mapping validated on {option.DateValidated}")">✓</span>
                            }
                        </div>
                    </button>
                }
            }
        </div>
        <div class="map-actions">
            <button class="btn map-action map-action-new" disabled="@_isBusy" @onclick="NewMappingAsync"><span class="map-action-emoji">+</span> New</button>
            <button class="btn map-action map-action-edit" disabled="@(!_canEdit)" @onclick="EditMappingAsync">&#x270E; Edit</button>
            <button class="btn map-action map-action-validate" disabled="@(!_canValidate)" @onclick="ValidateMapping">&#x2714; Validate</button>
            <div class="map-action-wrap" title="@AutomateTooltip">
                <button class="btn map-action map-action-deploy" disabled="@(!_canDeploy)" @onclick="DeployMappingAsync">&#x2699; Automate</button>
            </div>
            <button class="btn map-action map-action-delete" disabled="@(!_canDelete)" @onclick="DeleteMappingAsync">&#x1F5D1;&#xFE0F; Delete</button>
        </div>
    </section>

    <section class="card map-detail">
        <div class="map-status">@State.StatusMessage</div>

        @if (!ShowMappingDetails)
        {
            <div class="empty-state">Select a mapping to view details, or create a new one.</div>
        }
        else
        {
            <div class="map-section">
                <div class="section-title">Client Identity</div>
                <div class="map-form-grid map-form-grid-4">
                    <div class="map-form-field">
                        <label>Organization ID</label>
                        <input class="text-input" disabled="@(!State.IsEditing)" @bind="State.ClientId" @bind:event="oninput" @bind:after="OnClientIdChanged" />
                    </div>
                    <div class="map-form-field">
                        <label>Organization Name</label>
                        <input class="text-input" disabled="@(!State.IsEditing)" @bind="State.OrganizationName" @bind:event="oninput" @bind:after="OnOrganizationNameChanged" />
                    </div>
                    <div class="map-form-field">
                        <label>Sender Domain</label>
                        <input class="text-input" disabled="@(!State.IsEditing)" @bind="State.SenderDomain" @bind:event="oninput" @bind:after="OnSenderDomainChanged" />
                        @if (!string.IsNullOrWhiteSpace(SenderDomainWarning))
                        {
                            <div class="map-field-warning">@SenderDomainWarning</div>
                        }
                    </div>
                    <div class="map-form-field">
                        <label>FIX ID (Tag 115)</label>
                        <input class="text-input" disabled="@(!State.IsEditing)" @bind="State.OnBehalfOfCompId" @bind:event="oninput" @bind:after="OnOnBehalfOfCompChanged" />
                    </div>
                    <div class="map-form-field map-form-field-check">
                        <label class="check-input merge-allocations-toggle">
                            <input type="checkbox"
                                   checked="@(!State.DisableAllocationMerge)"
                                   disabled="@(!State.IsEditing)"
                                   @onchange="OnMergeAllocationsChanged" />
                            <span>Merge Allocations</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="map-section">
                <div class="section-title">Trade Allocation Field Mappings</div>
                <div class="map-field-grid">
                    <div class="map-field-list">
                        @if (State.FieldMappings.Count == 0)
                        {
                            <div class="empty-state">No fields mapped yet.</div>
                        }
                        else
                        {
                            @foreach (var field in State.FieldMappings)
                            {
                                var deps = GetDependencyTagsForField(field);
                                var missingDeps = State.IsEditing ? GetMissingDependenciesForField(field, deps) : Array.Empty<string>();
                                var hasMissingDeps = State.IsEditing && missingDeps.Count > 0;
                                <button class="map-field-row @(IsSelected(field) ? "is-selected" : string.Empty) @(State.IsEditing ? "is-editing" : string.Empty) @(hasMissingDeps ? "has-missing-deps" : string.Empty)"
                                        @onclick="() => SelectField(field)">
                                    <div class="map-field-left">
                                        <span class="tag-badge @TagLevelClass(field.TagLevel)">@field.TagLevel</span>
                                        <span class="map-field-tag">@field.TagDisplay</span>
                                    </div>
                                    <div class="map-field-column">
                                        <span class="map-field-column-name">@field.ColumnName</span>
                                        @if (deps.Count > 0)
                                        {
                                            <span class="map-field-meta">
                                                <span class="dep-badge" title="@GetDependencyTooltip(deps)">&#x1F517; Deps</span>
                                                @if (hasMissingDeps)
                                                {
                                                    <span class="dep-warn" title="@GetMissingDependencyTooltip(missingDeps)">!</span>
                                                }
                                            </span>
                                        }
                                    </div>
                                </button>
                            }
                        }
                    </div>
                    @if (State.IsEditing)
                    {
                        <div class="map-move">
                            <button class="btn" disabled="@(!_canMoveFieldUp)" @onclick="MoveFieldUp">&#9650;</button>
                            <button class="btn" disabled="@(!_canMoveFieldDown)" @onclick="MoveFieldDown">&#9660;</button>
                        </div>
                    }
                </div>

                @if (State.IsEditing)
                {
                    <div class="map-field-editor">
                        <div class="map-field-editor-title">Add/Edit Field</div>
                        <div class="map-field-editor-row">
                            <div class="map-field-actions">
                                <button class="icon-btn icon-add" type="button" disabled="@(!_canAddField)" @onclick="AddField" aria-label="Add" title="Add">
                                    <svg viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                                        <circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="3" />
                                        <path d="M24 16v16M16 24h16" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                                    </svg>
                                </button>
                                <button class="icon-btn icon-update" type="button" disabled="@(!_canUpdateField)" @onclick="UpdateField" aria-label="Update" title="Update">
                                    <svg viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                                        <path d="M34 18a12 12 0 0 0-20-4" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                                        <path d="M14 14h8v-8" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                        <path d="M14 30a12 12 0 0 0 20 4" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                                        <path d="M34 34h-8v8" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>
                                <button class="icon-btn icon-delete" type="button" disabled="@(!_canRemoveField)" @onclick="RemoveField" aria-label="Delete" title="Delete">
                                    <svg viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                                        <path d="M16 18h16l-1.5 18H17.5L16 18z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round" />
                                        <path d="M20 18V14h8v4M14 18h20" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                                        <path d="M22 24v8M26 24v8" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                                    </svg>
                                </button>
                            </div>
                            <div class="map-field-inputs">
                                <div class="map-field-input">
                                    <label>Tag ID</label>
                                    <div class="fix-suggest">
                                        <div class="tag-input-wrap">
                                            <div class="tag-input-overlay" aria-hidden="true">
                                                <span class="tag-typed">@State.NewFieldTagInput</span>
                                                @if (!string.IsNullOrWhiteSpace(TagSuffix))
                                                {
                                                    <span class="tag-suffix-inline @(_isTagInputFocused ? "" : "is-final")">@TagSuffix</span>
                                                }
                                            </div>
                                            <input class="text-input"
                                                   @bind="State.NewFieldTagInput"
                                                   @bind:event="oninput"
                                                   @bind:after="OnTagInputChanged"
                                                   @onkeydown="OnTagKeyDown"
                                                   @onkeydown:stopPropagation="State.IsFixFieldSuggestionOpen"
                                                    data-fixflow-tag-input="true"
                                                    @onfocus="OnTagFocus"
                                                    @onblur="OnTagBlur" />
                                        </div>
                                        @if (State.IsFixFieldSuggestionOpen && State.FixFieldSuggestions.Count > 0)
                                        {
                                            <div class="fix-suggest-list">
                                                @for (var i = 0; i < State.FixFieldSuggestions.Count; i++)
                                                {
                                                    var option = State.FixFieldSuggestions[i];
                                                    <button class="fix-suggest-item @(i == _suggestionIndex ? "is-active" : string.Empty)"
                                                            @onclick="() => SelectFixFieldSuggestion(option)"
                                                            @onmouseover="() => _suggestionIndex = i"
                                                            @onclick:preventDefault>
                                                        @option.Display
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="map-field-input">
                                    <label title="Use a number (1, 2, 3...) to indicate column position for headless spreadsheets.">Column Name or Position</label>
                                    <input class="text-input" @bind="State.NewFieldName" @bind:event="oninput" />
                                </div>
                            </div>
                        </div>
                        @if (State.IsEditing && MissingDependencyTags.Count > 0)
                        {
                            <div class="map-dependency-warning">
                                @DependencyAnchorTagDisplay may require: @string.Join(", ", DependencyTagDisplays).
                                If dependent tag(s) are not explicitely mapped to column(s), you may set their default values below.
                            </div>
                            <div class="map-defaults">
                                @foreach (var dep in MissingDependencyTags)
                                {
                                    var defaultValue = GetDefaultValue(dep);
                                    var enumOptions = GetTagEnumOptions(dep);
                                    var useEnumDropdown = enumOptions.Count > 0;
                                    var hasCustomDefault = useEnumDropdown &&
                                                           !string.IsNullOrWhiteSpace(defaultValue) &&
                                                           enumOptions.All(option => !string.Equals(option.Value, defaultValue, StringComparison.OrdinalIgnoreCase));
                                    <div class="map-default-row">
                                        <label>Default for @GetTagDisplay(dep)</label>
                                        @if (useEnumDropdown)
                                        {
                                            <select class="text-input"
                                                    value="@defaultValue"
                                                    @onchange="e => SetDefaultValue(dep, e.Value?.ToString())">
                                                <option value=""></option>
                                                @if (hasCustomDefault)
                                                {
                                                    <option value="@defaultValue">@defaultValue (current)</option>
                                                }
                                                @foreach (var enumOption in enumOptions)
                                                {
                                                    var description = string.IsNullOrWhiteSpace(enumOption.Description)
                                                        ? enumOption.Value
                                                        : $"{enumOption.Value} = {enumOption.Description}";
                                                    <option value="@enumOption.Value">@description</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            <input class="text-input"
                                                   value="@defaultValue"
                                                   @oninput="e => SetDefaultValue(dep, e.Value?.ToString())" />
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @if (State.IsEditing && !string.IsNullOrWhiteSpace(MissingRequiredTagsMessage))
            {
                <div class="map-required-warning">@MissingRequiredTagsMessage</div>
            }

            @if (State.IsEditing)
            {
                <div class="button-row">
                    <button class="btn primary" disabled="@(!_canSave)" @onclick="SaveMappingAsync">Save</button>
                    <button class="btn" @onclick="CancelAsync">Cancel</button>
                </div>
            }

            @if (!State.IsEditing)
            {
                <div class="map-meta">
                    <div><span class="label">Date Created:</span> <span class="value">@State.DateCreated</span></div>
                    @if (!string.IsNullOrWhiteSpace(State.DateModified))
                    {
                        <div><span class="label">Date Modified:</span> <span class="value">@State.DateModified</span></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(State.DateValidated))
                    {
                        <div><span class="label">Date Validated:</span> <span class="value">@State.DateValidated</span></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(State.EmailAutomationStatus))
                    {
                   <div><span class="label">Email Automation Status:</span> <span class="value">@State.EmailAutomationStatus</span></div>
                   }
               </div>
            }
        }
    </section>
</div>

@if (_showConfirm)
{
    <div class="ff-modal-backdrop" role="presentation">
        <div class="ff-modal" role="dialog" aria-modal="true" aria-labelledby="ffConfirmTitle">
            <div class="ff-modal-header" id="ffConfirmTitle">@_confirmTitle</div>
            <div class="ff-modal-body">@_confirmMessage</div>
            <div class="ff-modal-actions">
                <button class="btn primary" @onclick="ConfirmYes">@_confirmConfirmText</button>
                <button class="btn" @onclick="ConfirmNo">@_confirmCancelText</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _isBusy;
    private bool _suppressChangeTracking;
    private bool _suppressFixFieldSuggestion;
    private int _suggestionIndex = -1;
    private bool _isTagInputFocused;
    private bool _hasDependencyDefaultChanges;
    private bool _showConfirm;
    private string _confirmTitle = "Confirm";
    private string _confirmMessage = string.Empty;
    private string _confirmConfirmText = "OK";
    private string _confirmCancelText = "Cancel";
    private Func<Task>? _confirmYesAction;
    private Func<Task>? _confirmNoAction;
    private DotNetObjectReference<MapManagement>? _tagInputDotNetRef;

    protected override async Task OnInitializedAsync()
    {
        await EnsureFixFieldsLoadedAsync();
        await EnsureTagMetadataLoadedAsync();
        await LoadMappingsAsync();

        if (!State.IsEditing && !string.IsNullOrWhiteSpace(State.SelectedMapping))
        {
            await LoadMappingAsync(State.SelectedMapping);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (State.IsEditing)
        {
            _tagInputDotNetRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("fixflowTagSuggest.register", _tagInputDotNetRef);
            if (State.IsFixFieldSuggestionOpen)
            {
                await JS.InvokeVoidAsync("fixflowTagSuggest.updatePosition");
            }
        }
        else if (_tagInputDotNetRef is not null)
        {
            await JS.InvokeVoidAsync("fixflowTagSuggest.unregister");
        }
    }

    private bool ShowMappingDetails => !State.IsFirstVisit || State.SelectedMapping != null || State.IsEditing;

    private bool _canEdit => !_isBusy && State.SelectedMapping != null;
    private bool _canValidate => !_isBusy && !State.IsEditing && State.SelectedMapping != null;
    private bool _canDeploy => !_isBusy && IsDeploySelectionReady && HasSenderDomain;
    private bool _canDelete => !_isBusy && !State.IsEditing && State.SelectedMapping != null;
    private bool _canSave => !_isBusy && State.IsEditing && State.HasUnsavedChanges && HasRequiredTags && State.FieldMappings.Count > 0 && !string.IsNullOrWhiteSpace(State.ClientId);
    private bool _canAddField => State.IsEditing && CanAddField;
    private bool _canUpdateField => State.IsEditing && CanUpdateField;
    private bool _canRemoveField => State.IsEditing && State.SelectedFieldMapping is not null;
    private bool _canMoveFieldUp => State.IsEditing && GetSelectedFieldIndex() > 0;
    private bool _canMoveFieldDown => State.IsEditing && GetSelectedFieldIndex() >= 0 && GetSelectedFieldIndex() < State.FieldMappings.Count - 1;

    private static readonly string[] RequiredFixTags = { "54", "79", "80", "153" };

    private string MissingRequiredTagsMessage
    {
        get
        {
            var missing = RequiredFixTags
                .Where(tag => State.FieldMappings.All(f => !string.Equals(f.Tag.Trim(), tag, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            var hasTag55 = State.FieldMappings.Any(f => string.Equals(f.Tag.Trim(), "55", StringComparison.OrdinalIgnoreCase));
            var hasTag48 = State.FieldMappings.Any(f => string.Equals(f.Tag.Trim(), "48", StringComparison.OrdinalIgnoreCase));
            if (!hasTag55 && !hasTag48)
            {
                missing.Add("55 or 48");
            }
            return missing.Count == 0
                ? string.Empty
                : $"This map cannot be saved because it is missing the mapping for tag(s): {string.Join(", ", missing)}";
        }
    }

    private bool HasRequiredTags =>
        RequiredFixTags.All(tag =>
            State.FieldMappings.Any(f => string.Equals(f.Tag.Trim(), tag, StringComparison.OrdinalIgnoreCase)))
        && (State.FieldMappings.Any(f => string.Equals(f.Tag.Trim(), "55", StringComparison.OrdinalIgnoreCase))
            || State.FieldMappings.Any(f => string.Equals(f.Tag.Trim(), "48", StringComparison.OrdinalIgnoreCase)));

    private async Task LoadMappingsAsync(bool updateStatus = true)
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<MappingOption>>("api/mappings");
            State.MappingOptions.Clear();
            if (response is not null && response.Count > 0)
            {
                State.MappingOptions.AddRange(response);
            }
        }
        catch
        {
            State.MappingOptions.Clear();
        }

        if (State.SelectedMapping is not null &&
            State.MappingOptions.All(m => !string.Equals(m.ClientId, State.SelectedMapping, StringComparison.OrdinalIgnoreCase)))
        {
            State.SelectedMapping = null;
        }

        State.HasLoadedMappings = true;
        if (updateStatus && !State.IsEditing)
        {
            State.StatusMessage = $"Loaded {State.MappingOptions.Count} mapping(s)";
        }
    }

    private async Task EnsureFixFieldsLoadedAsync()
    {
        if (State.HasLoadedFixFields)
        {
            return;
        }

        try
        {
            var response = await Http.GetFromJsonAsync<List<FixFieldOption>>("api/map-management/fix-fields");
            State.FixFieldOptions.Clear();
            if (response is not null)
            {
                State.FixFieldOptions.AddRange(response);
            }
        }
        catch
        {
            State.FixFieldOptions.Clear();
        }

        State.HasLoadedFixFields = true;
    }

    private async Task EnsureTagMetadataLoadedAsync()
    {
        if (State.HasLoadedTagMetadata)
        {
            return;
        }

        try
        {
            var response = await Http.GetFromJsonAsync<List<FixTagMetadata>>("api/map-management/tag-metadata");
            State.TagMetadata.Clear();
            if (response is not null)
            {
                foreach (var item in response)
                {
                    if (!string.IsNullOrWhiteSpace(item.Tag))
                    {
                        State.TagMetadata[item.Tag] = item;
                    }
                }
            }
        }
        catch
        {
            State.TagMetadata.Clear();
        }

        State.HasLoadedTagMetadata = true;
    }

    private async Task SelectMappingAsync(string clientId)
    {
        State.IsFirstVisit = false;
        State.SelectedMapping = clientId;
        if (State.IsEditing)
        {
            return;
        }

        await LoadMappingAsync(clientId);
    }

    private async Task LoadMappingAsync(string clientId)
    {
        if (string.IsNullOrWhiteSpace(clientId))
        {
            return;
        }

        _suppressChangeTracking = true;
        try
        {
            var mapping = await Http.GetFromJsonAsync<MappingEditorDto>($"api/map-management/mapping/{Uri.EscapeDataString(clientId)}");
            if (mapping is null)
            {
                State.StatusMessage = "Mapping not found.";
                return;
            }

            ApplyMapping(mapping);
            State.StatusMessage = $"Loaded mapping: {mapping.ClientId}";
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Error loading mapping: {ex.Message}";
        }
        finally
        {
            _suppressChangeTracking = false;
        }
    }

    private void ApplyMapping(MappingEditorDto mapping)
    {
        State.ClientId = mapping.ClientId ?? string.Empty;
        State.OriginalClientId = mapping.ClientId ?? string.Empty;
        State.OrganizationName = mapping.OrganizationName ?? string.Empty;
        State.SenderDomain = mapping.SenderDomain ?? string.Empty;
        State.DisableAllocationMerge = mapping.DisableAllocationMerge;
        State.SenderCompId = mapping.SenderCompId ?? string.Empty;
        State.TargetCompId = mapping.TargetCompId ?? string.Empty;
        State.TargetSubId = mapping.TargetSubId ?? string.Empty;
        State.OnBehalfOfCompId = mapping.OnBehalfOfCompId ?? string.Empty;
        State.DeliverToCompId = mapping.DeliverToCompId ?? string.Empty;
        State.DateCreated = mapping.DateCreated ?? string.Empty;
        State.DateValidated = mapping.DateValidated ?? string.Empty;
        State.DateModified = mapping.DateModified ?? string.Empty;
        State.EmailAutomationStatus = mapping.EmailAutomationStatus ?? "Inactive";
        State.HasDeployedCopy = mapping.HasDeployedCopy;
        State.FieldMappings.Clear();
        State.DefaultTagValues.Clear();
        State.FieldDefaultTagValues.Clear();
        if (mapping.Fields is not null)
        {
            State.FieldMappings.AddRange(mapping.Fields);
        }
        if (mapping.Defaults is not null)
        {
            foreach (var entry in mapping.Defaults)
            {
                if (!string.IsNullOrWhiteSpace(entry.Tag))
                {
                    State.DefaultTagValues[entry.Tag.Trim()] = entry.Value ?? string.Empty;
                }
            }
        }
        if (mapping.FieldDefaults is not null)
        {
            foreach (var entry in mapping.FieldDefaults)
            {
                var column = entry.ColumnName?.Trim() ?? string.Empty;
                var tag = entry.Tag?.Trim() ?? string.Empty;
                var value = entry.Value?.Trim() ?? string.Empty;
                if (string.IsNullOrWhiteSpace(column) || string.IsNullOrWhiteSpace(tag) || string.IsNullOrWhiteSpace(value))
                {
                    continue;
                }

                if (!State.FieldDefaultTagValues.TryGetValue(column, out var tagDefaults))
                {
                    tagDefaults = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                    State.FieldDefaultTagValues[column] = tagDefaults;
                }

                tagDefaults[tag] = value;
            }
        }
        State.SelectedFieldMapping = null;
        State.NewFieldName = string.Empty;
        State.NewFieldTag = string.Empty;
        State.NewFieldTagInput = string.Empty;
        State.FixFieldSuggestions.Clear();
        State.IsFixFieldSuggestionOpen = false;
        _hasDependencyDefaultChanges = false;
        State.HasUnsavedChanges = false;
    }

    private async Task NewMappingAsync()
    {
        _suppressChangeTracking = true;
        try
        {
            var defaults = await Http.GetFromJsonAsync<MappingDefaultsResponse>("api/map-management/defaults");
            State.ClientId = string.Empty;
            State.OriginalClientId = null;
            State.OrganizationName = string.Empty;
            State.SenderDomain = string.Empty;
            State.DisableAllocationMerge = false;
            State.SenderCompId = defaults?.SenderCompId ?? string.Empty;
            State.TargetCompId = defaults?.TargetCompId ?? string.Empty;
            State.TargetSubId = defaults?.TargetSubId ?? string.Empty;
            State.OnBehalfOfCompId = defaults?.OnBehalfOfCompId ?? string.Empty;
            State.DeliverToCompId = defaults?.DeliverToCompId ?? string.Empty;
            State.DateCreated = string.Empty;
            State.DateValidated = string.Empty;
            State.DateModified = string.Empty;
            State.EmailAutomationStatus = "Inactive";
            State.HasDeployedCopy = false;
            State.FieldMappings.Clear();
            State.DefaultTagValues.Clear();
            State.FieldDefaultTagValues.Clear();
            var defaultFields = defaults?.DefaultFields?.ToList() ?? new List<MappingFieldInput>();
            if (defaultFields.Count == 0)
            {
                defaultFields.AddRange(new[]
                {
                    new MappingFieldInput("Side", "54"),
                    new MappingFieldInput("Symbol", "55"),
                    new MappingFieldInput("Trade Date", "75"),
                    new MappingFieldInput("Allocation Account", "79"),
                    new MappingFieldInput("Shares Qty", "80"),
                    new MappingFieldInput("Average Price", "153")
                });
            }

            foreach (var field in defaultFields)
            {
                var entry = BuildFieldEntry(field.ColumnName, field.Tag);
                State.FieldMappings.Add(entry);
            }
            State.SelectedFieldMapping = null;
            State.NewFieldName = string.Empty;
            State.NewFieldTag = string.Empty;
            State.NewFieldTagInput = string.Empty;
            State.FixFieldSuggestions.Clear();
            State.IsFixFieldSuggestionOpen = false;
            State.IsEditing = true;
            State.HasUnsavedChanges = true;
            State.IsFirstVisit = false;
            State.StatusMessage = "Creating new mapping...";
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Failed to load defaults: {ex.Message}";
        }
        finally
        {
            _suppressChangeTracking = false;
        }
    }

    private async Task EditMappingAsync()
    {
        if (string.IsNullOrWhiteSpace(State.SelectedMapping))
        {
            State.StatusMessage = "Please select a mapping to edit";
            return;
        }

        State.IsFirstVisit = false;
        var targetClientId = State.SelectedMapping;
        var currentClientId = State.ClientId;

        if (State.IsEditing &&
            !string.IsNullOrWhiteSpace(currentClientId) &&
            !string.Equals(currentClientId, targetClientId, StringComparison.OrdinalIgnoreCase))
        {
            if (State.HasUnsavedChanges)
            {
                ShowConfirm(
                    "Confirm Save",
                    $"Want to save your changes for \"{currentClientId}\" map?",
                    () => ConfirmEditSaveAsync(targetClientId!, currentClientId),
                    () => ConfirmEditDiscardAsync(targetClientId!));
                return;
            }
        }

        if (!string.Equals(State.ClientId, targetClientId, StringComparison.OrdinalIgnoreCase))
        {
            await LoadMappingAsync(targetClientId!);
        }

        State.IsEditing = true;
        State.HasUnsavedChanges = false;
        State.StatusMessage = $"Editing: {targetClientId}";
    }

    private async Task ConfirmEditSaveAsync(string targetClientId, string currentClientId)
    {
        await SaveMappingAsync();
        if (State.HasUnsavedChanges)
        {
            return;
        }

        if (!string.Equals(State.ClientId, targetClientId, StringComparison.OrdinalIgnoreCase))
        {
            await LoadMappingAsync(targetClientId);
        }

        State.IsEditing = true;
        State.HasUnsavedChanges = false;
        State.StatusMessage = $"Editing: {targetClientId}";
    }

    private async Task ConfirmEditDiscardAsync(string targetClientId)
    {
        await LoadMappingAsync(targetClientId);
        State.IsEditing = true;
        State.HasUnsavedChanges = false;
        State.StatusMessage = $"Editing: {targetClientId}";
    }

    private async Task SaveMappingAsync()
    {
        if (string.IsNullOrWhiteSpace(State.ClientId))
        {
            State.StatusMessage = "Client ID is required";
            return;
        }

        if (State.FieldMappings.Count == 0)
        {
            State.StatusMessage = "At least one field mapping is required";
            return;
        }

        if (!HasRequiredTags)
        {
            State.StatusMessage = "Missing required FIX fields. Please map tags 54, 79, 80, 153, and either 55 or 48 before saving.";
            return;
        }

        _isBusy = true;
        try
        {
            SyncDefaultValuesWithMappings();
            var fields = State.FieldMappings
                .Select(f => new MappingFieldInput(f.ColumnName.Trim(), f.Tag.Trim()))
                .Where(f => !string.IsNullOrWhiteSpace(f.ColumnName) && !string.IsNullOrWhiteSpace(f.Tag))
                .ToList();

            var defaults = State.DefaultTagValues
                .Where(kvp => !string.IsNullOrWhiteSpace(kvp.Key) && !string.IsNullOrWhiteSpace(kvp.Value))
                .Select(kvp => new MappingDefaultValue(kvp.Key.Trim(), kvp.Value.Trim()))
                .ToList();

            var fieldDefaults = new List<MappingFieldDefaultValue>();
            foreach (var columnEntry in State.FieldDefaultTagValues)
            {
                var column = columnEntry.Key?.Trim();
                if (string.IsNullOrWhiteSpace(column))
                {
                    continue;
                }

                foreach (var tagEntry in columnEntry.Value)
                {
                    var tag = tagEntry.Key?.Trim();
                    var value = tagEntry.Value?.Trim() ?? string.Empty;
                    if (string.IsNullOrWhiteSpace(tag) || string.IsNullOrWhiteSpace(value))
                    {
                        continue;
                    }

                    fieldDefaults.Add(new MappingFieldDefaultValue(column, tag, value));
                }
            }

            var request = new MappingSaveRequest(
                State.OriginalClientId,
                NormalizeUpper(State.ClientId),
                State.OrganizationName?.Trim() ?? string.Empty,
                NormalizeUpper(State.SenderDomain),
                State.DisableAllocationMerge,
                NormalizeUpper(State.SenderCompId),
                string.IsNullOrWhiteSpace(State.TargetCompId) ? "BROKER" : NormalizeUpper(State.TargetCompId),
                NormalizeUpper(State.TargetSubId),
                NormalizeUpper(State.OnBehalfOfCompId),
                NormalizeUpper(State.DeliverToCompId),
                fields,
                defaults,
                fieldDefaults);

            var response = await Http.PostAsJsonAsync("api/map-management/save", request);
            if (!response.IsSuccessStatusCode)
            {
                State.StatusMessage = $"Save failed ({response.StatusCode}).";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<MappingSaveResponse>();
            if (result is null)
            {
                State.StatusMessage = "Save failed: no response.";
                return;
            }

            State.StatusMessage = result.StatusMessage;
            if (!result.Success || result.Mapping is null)
            {
                return;
            }

            ApplyMapping(result.Mapping);
            State.IsEditing = false;
            State.HasUnsavedChanges = false;
            State.SelectedMapping = result.Mapping.ClientId;
            State.OriginalClientId = result.Mapping.ClientId;
            await LoadMappingsAsync(updateStatus: false);
            State.StatusMessage = result.StatusMessage;
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Error saving mapping: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CancelAsync()
    {
        if (!State.IsEditing)
        {
            return;
        }

        if (!State.HasUnsavedChanges)
        {
            await ApplyCancelAsync();
            return;
        }

        ShowConfirm(
            "Confirm Discard",
            "Discard changes?",
            ApplyCancelAsync,
            () =>
            {
                State.StatusMessage = "Cancel aborted";
                return Task.CompletedTask;
            });
    }

    private async Task ApplyCancelAsync()
    {
        State.IsEditing = false;
        State.HasUnsavedChanges = false;

        if (!string.IsNullOrWhiteSpace(State.SelectedMapping))
        {
            await LoadMappingAsync(State.SelectedMapping);
        }

        State.StatusMessage = "Cancelled";
    }
