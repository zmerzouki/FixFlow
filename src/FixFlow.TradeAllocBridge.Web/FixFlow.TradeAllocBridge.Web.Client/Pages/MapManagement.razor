    private void AddField()
    {
        if (string.IsNullOrWhiteSpace(State.NewFieldName) || string.IsNullOrWhiteSpace(State.NewFieldTag))
        {
            State.StatusMessage = "Field name and tag are required";
            return;
        }

        if (State.FieldMappings.Any(x => x.ColumnName.Equals(State.NewFieldName, StringComparison.OrdinalIgnoreCase)))
        {
            State.StatusMessage = "Field already exists";
            return;
        }

        var entry = BuildFieldEntry(State.NewFieldName.Trim(), State.NewFieldTag.Trim());
        State.FieldMappings.Add(entry);
        State.NewFieldName = string.Empty;
        State.NewFieldTag = string.Empty;
        State.NewFieldTagInput = string.Empty;
        _hasDependencyDefaultChanges = false;
        SyncDefaultValuesWithMappings();
        MarkDirty();
    }

    private void UpdateField()
    {
        if (State.SelectedFieldMapping is null)
        {
            State.StatusMessage = "Select a field to update";
            return;
        }

        if (string.IsNullOrWhiteSpace(State.NewFieldName) || string.IsNullOrWhiteSpace(State.NewFieldTag))
        {
            State.StatusMessage = "Field name and tag are required";
            return;
        }

        var hasFieldChanges = IsFieldDirty;
        var duplicate = State.FieldMappings.Any(x =>
            !string.Equals(x.ColumnName, State.SelectedFieldMapping.ColumnName, StringComparison.OrdinalIgnoreCase) &&
            x.ColumnName.Equals(State.NewFieldName, StringComparison.OrdinalIgnoreCase));
        if (duplicate)
        {
            State.StatusMessage = "Field name already exists";
            return;
        }

        var index = GetSelectedFieldIndex();
        if (index >= 0)
        {
            var previousColumn = State.SelectedFieldMapping.ColumnName;
            var updated = BuildFieldEntry(State.NewFieldName.Trim(), State.NewFieldTag.Trim());
            if (hasFieldChanges)
            {
                State.FieldMappings[index] = updated;
            }
            State.SelectedFieldMapping = updated;
            State.NewFieldTagInput = State.NewFieldTag;
            State.StatusMessage = hasFieldChanges ? "Field updated" : "Field defaults updated";
            if (!string.Equals(previousColumn, updated.ColumnName, StringComparison.OrdinalIgnoreCase))
            {
                MoveFieldDefaults(previousColumn, updated.ColumnName);
            }
            _hasDependencyDefaultChanges = false;
            SyncDefaultValuesWithMappings();
            MarkDirty();
        }
    }

    private void RemoveField()
    {
        if (State.SelectedFieldMapping is null)
        {
            return;
        }

        var index = GetSelectedFieldIndex();
        if (index >= 0)
        {
            var column = State.SelectedFieldMapping.ColumnName;
            State.FieldMappings.RemoveAt(index);
            State.SelectedFieldMapping = null;
            RemoveFieldDefaults(column);
            _hasDependencyDefaultChanges = false;
            SyncDefaultValuesWithMappings();
            MarkDirty();
        }
    }

    private void MoveFieldUp()
    {
        var index = GetSelectedFieldIndex();
        if (index <= 0)
        {
            return;
        }

        var item = State.FieldMappings[index];
        State.FieldMappings.RemoveAt(index);
        State.FieldMappings.Insert(index - 1, item);
        State.SelectedFieldMapping = State.FieldMappings[index - 1];
        MarkDirty();
    }

    private void MoveFieldDown()
    {
        var index = GetSelectedFieldIndex();
        if (index < 0 || index >= State.FieldMappings.Count - 1)
        {
            return;
        }

        var item = State.FieldMappings[index];
        State.FieldMappings.RemoveAt(index);
        State.FieldMappings.Insert(index + 1, item);
        State.SelectedFieldMapping = State.FieldMappings[index + 1];
        MarkDirty();
    }

    private void SelectField(MappingFieldEntry field)
    {
        State.SelectedFieldMapping = field;
        State.NewFieldName = field.ColumnName;
        State.NewFieldTag = field.Tag;
        State.NewFieldTagInput = field.Tag;
        State.FixFieldSuggestions.Clear();
        State.IsFixFieldSuggestionOpen = false;
        _hasDependencyDefaultChanges = false;
    }

    private bool CanAddField
    {
        get
        {
            if (string.IsNullOrWhiteSpace(State.NewFieldName) || string.IsNullOrWhiteSpace(State.NewFieldTag))
            {
                return false;
            }

            if (State.SelectedFieldMapping is not null && !IsFieldDirty)
            {
                return false;
            }

            return true;
        }
    }

    private bool CanUpdateField => State.SelectedFieldMapping is not null && (IsFieldDirty || _hasDependencyDefaultChanges) &&
                                   !string.IsNullOrWhiteSpace(State.NewFieldName) &&
                                   !string.IsNullOrWhiteSpace(State.NewFieldTag);

    private bool IsFieldDirty => State.SelectedFieldMapping is null ||
                                 !string.Equals(State.SelectedFieldMapping.ColumnName, State.NewFieldName, StringComparison.Ordinal) ||
                                 !string.Equals(State.SelectedFieldMapping.Tag, State.NewFieldTag, StringComparison.OrdinalIgnoreCase);

    private void OnTagInputChanged()
    {
        if (_suppressFixFieldSuggestion)
        {
            return;
        }

        State.FixFieldSuggestions.Clear();
        State.IsFixFieldSuggestionOpen = false;

        var input = State.NewFieldTagInput?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(input))
        {
            State.NewFieldTag = string.Empty;
            return;
        }

        var numericPrefix = new string(input.TakeWhile(char.IsDigit).ToArray());
        if (!string.IsNullOrWhiteSpace(numericPrefix))
        {
            State.NewFieldTag = numericPrefix;
            return;
        }

        State.NewFieldTag = string.Empty;

        if (!char.IsLetter(input[0]))
        {
            return;
        }

        var existingTags = State.FieldMappings
            .Select(f => f.Tag.Trim())
            .Where(tag => !string.IsNullOrWhiteSpace(tag))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var matches = input.Length <= 2
            ? State.FixFieldOptions
                .Where(option => !existingTags.Contains(option.Tag) &&
                                 option.Name.StartsWith(input, StringComparison.OrdinalIgnoreCase))
                .ToList()
            : State.FixFieldOptions
                .Where(option => !existingTags.Contains(option.Tag) &&
                                 option.Name.Contains(input, StringComparison.OrdinalIgnoreCase))
                .ToList();

        foreach (var match in matches.Take(20))
        {
            State.FixFieldSuggestions.Add(match);
        }

        State.IsFixFieldSuggestionOpen = State.FixFieldSuggestions.Count > 0;
        _suggestionIndex = State.IsFixFieldSuggestionOpen ? 0 : -1;
    }

    private void SelectFixFieldSuggestion(FixFieldOption option)
    {
        _suppressFixFieldSuggestion = true;
        State.NewFieldTag = option.Tag;
        State.NewFieldTagInput = option.Tag;
        _suppressFixFieldSuggestion = false;
        State.IsFixFieldSuggestionOpen = false;
        State.FixFieldSuggestions.Clear();
        _suggestionIndex = -1;
    }

    private void OnTagFocus()
    {
        _isTagInputFocused = true;
    }

    private void OnTagBlur()
    {
        _isTagInputFocused = false;
        FormatTagInput();
    }

    private void FormatTagInput()
    {
        if (string.IsNullOrWhiteSpace(State.NewFieldTagInput))
        {
            return;
        }

        var trimmed = State.NewFieldTagInput.Trim();
        var numericPrefix = new string(trimmed.TakeWhile(char.IsDigit).ToArray());
        if (string.IsNullOrWhiteSpace(numericPrefix))
        {
            return;
        }

        State.NewFieldTag = numericPrefix;
        State.NewFieldTagInput = numericPrefix;
    }

    private string TagSuffix
    {
        get
        {
            if (string.IsNullOrWhiteSpace(State.NewFieldTag))
            {
                return string.Empty;
            }

            return State.TagMetadata.TryGetValue(State.NewFieldTag, out var meta) && !string.IsNullOrWhiteSpace(meta.Name)
                ? $"({meta.Name})"
                : string.Empty;
        }
    }

    private static readonly Dictionary<string, string[]> TagDependencies = new(StringComparer.OrdinalIgnoreCase)
    {
        ["12"] = new[] { "13" },   // Commission -> CommType
        ["13"] = new[] { "12" },   // CommType -> Commission
        ["137"] = new[] { "139", "138" }, // MiscFeeAmt -> MiscFeeType + MiscFeeCurr
        ["139"] = new[] { "137", "138" }  // MiscFeeType -> MiscFeeAmt + MiscFeeCurr
    };

    private IReadOnlyList<string> MissingDependencyTags
    {
        get
        {
            var anchor = NormalizeTagKey(State.NewFieldTag);
            if (string.IsNullOrWhiteSpace(anchor))
            {
                return Array.Empty<string>();
            }

            if (!TagDependencies.TryGetValue(anchor, out var deps))
            {
                return Array.Empty<string>();
            }
            var normalized = deps
                .Select(NormalizeTagKey)
                .Where(tag => !string.IsNullOrWhiteSpace(tag))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (UseFieldDefaultsForAnchor)
            {
                return normalized;
            }

            return normalized
                .Where(tag => !IsTagMapped(tag))
                .ToList();
        }
    }

    private IReadOnlyList<string> DependencyTagDisplays =>
        MissingDependencyTags.Select(GetTagDisplay).ToList();

    private string DependencyAnchorTagDisplay =>
        string.IsNullOrWhiteSpace(State.NewFieldTag) ? "tag" : GetTagDisplay(NormalizeTagKey(State.NewFieldTag));

    private bool IsTagMapped(string tag) =>
        State.FieldMappings.Any(f => string.Equals(NormalizeTagKey(f.Tag), tag, StringComparison.OrdinalIgnoreCase));

    private IReadOnlyList<string> GetDependencyTagsForField(MappingFieldEntry field)
    {
        var tag = NormalizeTagKey(field.Tag);
        if (string.IsNullOrWhiteSpace(tag))
        {
            return Array.Empty<string>();
        }

        if (!TagDependencies.TryGetValue(tag, out var deps) || deps.Length == 0)
        {
            return Array.Empty<string>();
        }

        return deps
            .Select(NormalizeTagKey)
            .Where(dep => !string.IsNullOrWhiteSpace(dep))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private IReadOnlyList<string> GetMissingDependenciesForField(MappingFieldEntry field, IReadOnlyList<string> deps)
    {
        if (deps.Count == 0)
        {
            return Array.Empty<string>();
        }

        var missing = new List<string>();
        foreach (var dep in deps)
        {
            if (IsTagMapped(dep))
            {
                continue;
            }

            var hasDefault = false;
            if (TryGetFieldDefaultValue(field.ColumnName, dep, out var fieldDefault) && !string.IsNullOrWhiteSpace(fieldDefault))
            {
                hasDefault = true;
            }
            else if (State.DefaultTagValues.TryGetValue(dep, out var globalDefault) && !string.IsNullOrWhiteSpace(globalDefault))
            {
                hasDefault = true;
            }

            if (!hasDefault)
            {
                missing.Add(dep);
            }
        }

        return missing;
    }

    private string GetDependencyTooltip(IReadOnlyList<string> deps) =>
        deps.Count == 0
            ? string.Empty
            : $"Depends on tags: {string.Join(", ", deps.Select(GetTagDisplay))}";

    private string GetMissingDependencyTooltip(IReadOnlyList<string> deps) =>
        deps.Count == 0
            ? string.Empty
            : $"Missing dependent tags: {string.Join(", ", deps.Select(GetTagDisplay))}";

    private static string NormalizeTagKey(string? tag)
    {
        if (string.IsNullOrWhiteSpace(tag))
        {
            return string.Empty;
        }

        var digits = new string(tag.Trim().Where(char.IsDigit).ToArray());
        return digits;
    }

    private string GetTagDisplay(string tag)
    {
        var trimmed = NormalizeTagKey(tag);
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return "Tag";
        }

        if (State.TagMetadata.TryGetValue(trimmed, out var meta) && !string.IsNullOrWhiteSpace(meta.Name))
        {
            return $"Tag {trimmed} ({meta.Name})";
        }

        return $"Tag {trimmed}";
    }

    private string GetDefaultValue(string tag)
    {
        var key = NormalizeTagKey(tag);
        if (string.IsNullOrWhiteSpace(key))
        {
            return string.Empty;
        }

        if (UseFieldDefaultsForAnchor && TryGetFieldDefaultValue(State.NewFieldName, key, out var value))
        {
            return value;
        }

        if (UseFieldDefaultsForAnchor && UseBlankDefaultsForAnchor)
        {
            return string.Empty;
        }

        return State.DefaultTagValues.TryGetValue(key, out var global) ? global : string.Empty;
    }

    private IReadOnlyList<FixTagEnumOption> GetTagEnumOptions(string tag)
    {
        var key = NormalizeTagKey(tag);
        if (string.IsNullOrWhiteSpace(key))
        {
            return Array.Empty<FixTagEnumOption>();
        }

        return State.TagMetadata.TryGetValue(key, out var meta) && meta.Enums is { Count: > 0 }
            ? meta.Enums
            : Array.Empty<FixTagEnumOption>();
    }

    private void SetDefaultValue(string tag, string? value)
    {
        var key = NormalizeTagKey(tag);
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        if (UseFieldDefaultsForAnchor && !string.IsNullOrWhiteSpace(State.NewFieldName))
        {
            SetFieldDefaultValue(State.NewFieldName, key, value);
            if (State.SelectedFieldMapping is not null)
            {
                _hasDependencyDefaultChanges = true;
            }
            return;
        }

        if (string.IsNullOrWhiteSpace(value))
        {
            State.DefaultTagValues.Remove(key);
        }
        else
        {
            State.DefaultTagValues[key] = value.Trim();
        }

        if (State.SelectedFieldMapping is not null)
        {
            _hasDependencyDefaultChanges = true;
        }

        MarkDirty();
    }

    private void SyncDefaultValuesWithMappings()
    {
        if (State.DefaultTagValues.Count == 0)
        {
            SyncFieldDefaultValuesWithMappings();
            return;
        }

        var mappedTags = State.FieldMappings
            .Select(f => NormalizeTagKey(f.Tag))
            .Where(tag => !string.IsNullOrWhiteSpace(tag))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var toRemove = State.DefaultTagValues.Keys
            .Where(tag => mappedTags.Contains(NormalizeTagKey(tag)))
            .ToList();

        foreach (var tag in toRemove)
        {
            State.DefaultTagValues.Remove(tag);
        }

        SyncFieldDefaultValuesWithMappings();
    }

    private void SyncFieldDefaultValuesWithMappings()
    {
        if (State.FieldDefaultTagValues.Count == 0)
        {
            return;
        }

        var mappedColumns = State.FieldMappings
            .Select(f => f.ColumnName?.Trim())
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var toRemove = State.FieldDefaultTagValues.Keys
            .Where(column => !mappedColumns.Contains(column))
            .ToList();

        foreach (var column in toRemove)
        {
            State.FieldDefaultTagValues.Remove(column);
        }
    }

    private bool UseFieldDefaultsForAnchor
    {
        get
        {
            var anchor = NormalizeTagKey(State.NewFieldTag);
            return string.Equals(anchor, "137", StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(anchor, "139", StringComparison.OrdinalIgnoreCase);
        }
    }

    private bool UseBlankDefaultsForAnchor =>
        string.Equals(NormalizeTagKey(State.NewFieldTag), "137", StringComparison.OrdinalIgnoreCase);

    private bool TryGetFieldDefaultValue(string? columnName, string tag, out string value)
    {
        value = string.Empty;
        if (string.IsNullOrWhiteSpace(columnName))
        {
            return false;
        }

        var column = columnName.Trim();
        if (!State.FieldDefaultTagValues.TryGetValue(column, out var tagDefaults))
        {
            return false;
        }

        if (tagDefaults.TryGetValue(tag, out var direct) && !string.IsNullOrWhiteSpace(direct))
        {
            value = direct;
            return true;
        }

        foreach (var kvp in tagDefaults)
        {
            if (NormalizeTagKey(kvp.Key) == tag && !string.IsNullOrWhiteSpace(kvp.Value))
            {
                value = kvp.Value;
                return true;
            }
        }

        return false;
    }

    private void SetFieldDefaultValue(string columnName, string tag, string? value)
    {
        var column = columnName?.Trim();
        if (string.IsNullOrWhiteSpace(column))
        {
            return;
        }

        if (!State.FieldDefaultTagValues.TryGetValue(column, out var tagDefaults))
        {
            tagDefaults = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            State.FieldDefaultTagValues[column] = tagDefaults;
        }

        if (string.IsNullOrWhiteSpace(value))
        {
            tagDefaults.Remove(tag);
            if (tagDefaults.Count == 0)
            {
                State.FieldDefaultTagValues.Remove(column);
            }
        }
        else
        {
            tagDefaults[tag] = value.Trim();
        }

        MarkDirty();
    }

    private void RemoveFieldDefaults(string? columnName)
    {
        var column = columnName?.Trim();
        if (string.IsNullOrWhiteSpace(column))
        {
            return;
        }

        State.FieldDefaultTagValues.Remove(column);
    }

    private void MoveFieldDefaults(string? fromColumn, string? toColumn)
    {
        var from = fromColumn?.Trim();
        var to = toColumn?.Trim();
        if (string.IsNullOrWhiteSpace(from) || string.IsNullOrWhiteSpace(to))
        {
            return;
        }

        if (!State.FieldDefaultTagValues.TryGetValue(from, out var existing))
        {
            return;
        }

        State.FieldDefaultTagValues.Remove(from);
        if (!State.FieldDefaultTagValues.TryGetValue(to, out var target))
        {
            State.FieldDefaultTagValues[to] = existing;
            return;
        }

        foreach (var kvp in existing)
        {
            target[kvp.Key] = kvp.Value;
        }
    }

    private async Task OnTagKeyDown(KeyboardEventArgs e)
    {
        await HandleTagSuggestKeyAsync(e.Key);
    }

    [JSInvokable]
    public async Task HandleTagSuggestKeyAsync(string? key)
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return;
        }

        if (!State.IsFixFieldSuggestionOpen || State.FixFieldSuggestions.Count == 0)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        switch (key)
        {
            case "ArrowDown":
                _suggestionIndex = _suggestionIndex < 0
                    ? 0
                    : Math.Min(_suggestionIndex + 1, State.FixFieldSuggestions.Count - 1);
                break;
            case "ArrowUp":
                _suggestionIndex = _suggestionIndex <= 0
                    ? State.FixFieldSuggestions.Count - 1
                    : _suggestionIndex - 1;
                break;
            case "Enter":
                if (_suggestionIndex >= 0 && _suggestionIndex < State.FixFieldSuggestions.Count)
                {
                    SelectFixFieldSuggestion(State.FixFieldSuggestions[_suggestionIndex]);
                }
                break;
            case "Escape":
                State.IsFixFieldSuggestionOpen = false;
                State.FixFieldSuggestions.Clear();
                _suggestionIndex = -1;
                break;
            default:
                return;
        }

        await InvokeAsync(StateHasChanged);
        if (State.IsFixFieldSuggestionOpen)
        {
            await JS.InvokeVoidAsync("fixflowTagSuggest.ensureActiveVisible");
        }
    }

    private void ShowConfirm(
        string title,
        string message,
        Func<Task> yesAction,
        Func<Task>? noAction = null,
        string confirmText = "OK",
        string cancelText = "Cancel")
    {
        _confirmTitle = title;
        _confirmMessage = message;
        _confirmConfirmText = confirmText;
        _confirmCancelText = cancelText;
        _confirmYesAction = yesAction;
        _confirmNoAction = noAction;
        _showConfirm = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmYes()
    {
        _showConfirm = false;
        var action = _confirmYesAction;
        _confirmYesAction = null;
        _confirmNoAction = null;
        _ = InvokeAsync(StateHasChanged);
        if (action != null)
        {
            await action();
        }
    }

    private async Task ConfirmNo()
    {
        _showConfirm = false;
        var action = _confirmNoAction;
        _confirmYesAction = null;
        _confirmNoAction = null;
        _ = InvokeAsync(StateHasChanged);
        if (action != null)
        {
            await action();
        }
    }

    private void OnClientIdChanged()
    {
        State.ClientId = NormalizeUpper(State.ClientId);
        MarkDirty();
    }

    private void OnOrganizationNameChanged()
    {
        State.OrganizationName = string.IsNullOrWhiteSpace(State.OrganizationName)
            ? string.Empty
            : State.OrganizationName.ToUpperInvariant();
        MarkDirty();
    }

    private void OnSenderDomainChanged()
    {
        State.SenderDomain = NormalizeUpper(State.SenderDomain);
        MarkDirty();
    }

    private void OnMergeAllocationsChanged(ChangeEventArgs args)
    {
        var mergeEnabled = args.Value is bool value && value;
        State.DisableAllocationMerge = !mergeEnabled;
        MarkDirty();
    }

    private void OnOnBehalfOfCompChanged()
    {
        State.OnBehalfOfCompId = NormalizeUpper(State.OnBehalfOfCompId);
        MarkDirty();
    }

    private void MarkDirty()
    {
        if (_suppressChangeTracking)
        {
            return;
        }

        State.HasUnsavedChanges = true;
    }

    private int GetSelectedFieldIndex()
    {
        if (State.SelectedFieldMapping is null)
        {
            return -1;
        }

        var selected = State.SelectedFieldMapping;
        for (var i = 0; i < State.FieldMappings.Count; i++)
        {
            var item = State.FieldMappings[i];
            if (string.Equals(item.ColumnName, selected.ColumnName, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(item.Tag, selected.Tag, StringComparison.OrdinalIgnoreCase))
            {
                return i;
            }
        }

        return -1;
    }

    private bool IsSelected(MappingOption option) =>
        State.SelectedMapping is not null && string.Equals(State.SelectedMapping, option.ClientId, StringComparison.OrdinalIgnoreCase);

    private bool IsSelected(MappingFieldEntry field) =>
        State.SelectedFieldMapping is not null &&
        string.Equals(State.SelectedFieldMapping.ColumnName, field.ColumnName, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(State.SelectedFieldMapping.Tag, field.Tag, StringComparison.OrdinalIgnoreCase);

    private MappingFieldEntry BuildFieldEntry(string columnName, string tag)
    {
        var tagDisplay = FormatTagDisplay(tag);
        var tagLevel = GetTagLevel(tag);
        return new MappingFieldEntry(columnName, tag, tagDisplay, tagLevel);
    }

    private string FormatTagDisplay(string tag)
    {
        var trimmed = tag.Trim();
        if (State.TagMetadata.TryGetValue(trimmed, out var meta) && !string.IsNullOrWhiteSpace(meta.Name))
        {
            return $"Tag {trimmed} ({meta.Name})";
        }

        return string.IsNullOrWhiteSpace(trimmed) ? string.Empty : $"Tag {trimmed}";
    }

    private string GetTagLevel(string tag)
    {
        var trimmed = tag.Trim();
        if (State.TagMetadata.TryGetValue(trimmed, out var meta) && !string.IsNullOrWhiteSpace(meta.Level))
        {
            return meta.Level;
        }

        return "Unknown";
    }

    private static string TagLevelClass(string level)
    {
        if (string.Equals(level, "NoAllocs", StringComparison.OrdinalIgnoreCase))
        {
            return "noallocs";
        }

        if (string.Equals(level, "NoMiscFees", StringComparison.OrdinalIgnoreCase))
        {
            return "nomiscfees";
        }

        if (string.Equals(level, "Header", StringComparison.OrdinalIgnoreCase))
        {
            return "header";
        }

        return "unknown";
    }

    private static string NormalizeUpper(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? string.Empty : value.Trim().ToUpperInvariant();
    }

    private bool IsDeploySelectionReady => !State.IsEditing && State.SelectedMapping != null;
    private bool HasSenderDomain => !string.IsNullOrWhiteSpace(State.SenderDomain);

    private string AutomateTooltip =>
        IsDeploySelectionReady && !HasSenderDomain
            ? "Enter a sender domain to enable email automation"
            : string.Empty;

    private string SenderDomainWarning
    {
        get
        {
            if (!State.IsEditing)
            {
                return string.Empty;
            }

            var senderDomain = NormalizeUpper(State.SenderDomain);
            if (string.IsNullOrWhiteSpace(senderDomain))
            {
                return string.Empty;
            }

            var currentId = NormalizeUpper(State.ClientId);
            foreach (var option in State.MappingOptions)
            {
                if (option is null)
                {
                    continue;
                }

                if (string.Equals(NormalizeUpper(option.ClientId), currentId, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                var optionDomain = NormalizeUpper(option.SenderDomain);
                if (string.IsNullOrWhiteSpace(optionDomain))
                {
                    continue;
                }

                if (string.Equals(optionDomain, senderDomain, StringComparison.OrdinalIgnoreCase))
                {
                    return $"Sender domain already used by {option.ClientId}.";
                }
            }

            return string.Empty;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_tagInputDotNetRef is not null)
        {
            await JS.InvokeVoidAsync("fixflowTagSuggest.unregister");
        }

        _tagInputDotNetRef?.Dispose();
        _tagInputDotNetRef = null;
    }

