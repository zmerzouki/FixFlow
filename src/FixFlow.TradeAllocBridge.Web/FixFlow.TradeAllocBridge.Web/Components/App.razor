@using System.Reflection
@using System.IO
@{
    var assemblyPath = Assembly.GetExecutingAssembly().Location;
    var assetVersion = File.Exists(assemblyPath)
        ? File.GetLastWriteTimeUtc(assemblyPath).ToString("yyyyMMddHHmmss")
        : (Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "1");
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <meta name="fixflow-asset-version" content="@assetVersion" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css?v=@assetVersion" />
    <link rel="stylesheet" href="app.css?v=@assetVersion" />
    <link rel="stylesheet" href="FixFlow.TradeAllocBridge.Web.styles.css?v=@assetVersion" />
    <link rel="icon" type="image/png" href="favicon.png?v=@assetVersion" />
    <HeadOutlet @rendermode="InteractiveWebAssembly" />
</head>

<body>
    <Routes @rendermode="InteractiveWebAssembly" />
    <script src="app.js?v=@assetVersion"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
