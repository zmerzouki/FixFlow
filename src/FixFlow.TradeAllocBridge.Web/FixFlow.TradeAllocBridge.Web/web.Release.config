<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <aspNetCore xdt:Transform="InsertIfMissing">
        <environmentVariables xdt:Transform="InsertIfMissing">
          <environmentVariable name="FIXFLOW_CLI_CONFIGS" value="..\FixFlowService\configs" xdt:Transform="Insert" />
          <environmentVariable name="FIXFLOW_CLI_REPORTS" value="..\FixFlowService\reports" xdt:Transform="Insert" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
