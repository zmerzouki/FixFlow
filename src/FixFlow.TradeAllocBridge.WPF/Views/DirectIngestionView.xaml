<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="FixFlow.TradeAllocBridge.WPF.Views.DirectIngestionView"
             xmlns:converters="clr-namespace:FixFlow.TradeAllocBridge.WPF.Converters"
             x:Name="DirectIngestionViewControl"
             Background="#ffffff">
    <UserControl.Resources>
        <converters:PercentageToGridLengthConverter x:Key="PercentageToStarConverter"/>
    </UserControl.Resources>
    <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">
            <!-- Client Selection Section -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,5">
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#333"><Run Text="1. Select Client"/></TextBlock>
                <ComboBox x:Name="ClientComboBox"
                          ItemsSource="{Binding AvailableClients}"
                          SelectedValuePath="Key"
                          DisplayMemberPath="Value"
                          Padding="10"
                          FontSize="12"
                          Height="38"
                          SelectedItem="{Binding SelectedClient, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock FontSize="11" Foreground="#999" TextWrapping="Wrap" Height="17"><Run Text="Select a client from the dropdown. The corresponding field mapping will be loaded automatically."/></TextBlock>
                <Grid Margin="0,3,0,3"
                      Visibility="{Binding RequiresOnBehalfOfCompId, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#333"
                               VerticalAlignment="Center"><Run Text="⚠️ "/><Run Text=" "/><Run Text="ENTER FIX ID (115):"/></TextBlock>
                    <TextBox Grid.Column="1"
                             Text="{Binding EnteredOnBehalfOfCompId, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8"
                             FontSize="12"
                             Margin="10,0,0,0"
                             Foreground="#FF0E0101"
                             BorderBrush="#FFABB3AD"/>
                </Grid>
            </StackPanel>
            <!-- Client Info Display -->
            <Border Style="{StaticResource DragDropZone}" Padding="10" Height="107">
                <StackPanel Orientation="Vertical">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="Client Mapping Info"/></TextBlock>
                    <TextBlock FontSize="11" Foreground="#666"><Run FontWeight="Bold" Text="Client ID:"/><Run Text=" "/><Run Text="{Binding SelectedClientId, FallbackValue=(None selected), Mode=OneWay}"/></TextBlock>
                    <TextBlock FontSize="11" Foreground="#666"><Run FontWeight="Bold" Text="Sender Domain:"/><Run Text=" "/><Run Text="{Binding SelectedClientDomain, FallbackValue=(None selected), Mode=OneWay}"/></TextBlock>
                    <TextBlock FontSize="11" Foreground="#666"><Run FontWeight="Bold" Text="FIX Sender/Target:"/><Run Text=" "/><Run Text="{Binding SelectedClientFix, FallbackValue=(None selected), Mode=OneWay}"/></TextBlock>
                    <TextBlock FontSize="10" Foreground="#999" TextWrapping="Wrap" Margin="0,5,0,0" Height="17"><Run Text="{Binding MappedFieldsCount, Mode=OneWay}"/><Run Text=" field(s) mapped in configuration"/></TextBlock>
                </StackPanel>
            </Border>

            <!-- File Drop Zone Section -->
            <StackPanel Orientation="Vertical" Margin="0,5,0,5">
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#333"><Run Text="2. Select Spreadsheet"/></TextBlock>
                <Border x:Name="DropZone"
                        Style="{StaticResource DragDropZone}"
                        AllowDrop="True"
                        Padding="10,5,10,5"
                        MinHeight="120" Height="161">
                    <StackPanel Orientation="Vertical" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="0,0,0,5">
                        <TextBlock FontSize="32" TextAlignment="Center" Foreground="#0078d4" Height="46"><Run Text="📁"/></TextBlock>
                        <TextBlock FontSize="13" FontWeight="SemiBold" TextAlignment="Center" Foreground="#333" Text="Drag and drop a spreadsheet here"/>
                        <!-- Selected File Info -->
                        <TextBlock FontSize="14" FontWeight="Bold" Foreground="#FFFEFDFC" 
                       Visibility="{Binding SelectedFilePath, Converter={StaticResource StringToVisibilityConverter}}" Background="#FF4E566A" TextAlignment="Center">
                            <Run Text="Selected File: "/>
                            <Run Text="{Binding SelectedFileName, Mode=OneWay}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding SelectedFileSizeKb, Mode=OneWay}"/>
                            <Run Text=" KB)"/>
                        </TextBlock>
                        <TextBlock FontSize="11" TextAlignment="Center" Foreground="#666" Text="OR"/>
                        <Button x:Name="BrowseButton" 
                                Content="Browse File"
                                Style="{StaticResource PrimaryButton}"
                                Width="120"
                                HorizontalAlignment="Center"
                                Command="{Binding BrowseFileCommand}" FontWeight="SemiBold"/>
                        <TextBlock FontSize="10" TextAlignment="Center" Foreground="#999"><Run Text="Supported: .xlsx, .xls, .csv"/></TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Processing Options Section -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,5" Height="96">
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#333" Height="22"><Run Text="3. Processing Options"/></TextBlock>
                <CheckBox Content="Dry-run mode (validate only, don't send to trading backend)" 
                          IsChecked="{Binding IsDryRun, UpdateSourceTrigger=PropertyChanged}"
                          FontSize="12"
                          VerticalContentAlignment="Center"
                          Padding="5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Button Content="Submit"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,8"
                            Width="120"
                            Margin="0,0,10,0"
                            Command="{Binding ProcessCommand}"
                            IsEnabled="{Binding CanProcess}" FontWeight="SemiBold"/>
                    <Button Content="Discard"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,8"
                            Width="120"
                            Background="#d13438"
                            Command="{Binding DiscardCommand}" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333" Height="18"><Run Text="Processing Progress"/></TextBlock>

            <!-- Progress Section -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <Grid>
                    <ProgressBar Height="13" Value="{Binding ProcessProgress}" Maximum="100" Foreground="#0078d4">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowResults}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <Border Height="13"
                            Background="#e5e5e5"
                            CornerRadius="4"
                            Visibility="{Binding ShowResults, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding DataContext.FailedAllocationPercentage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource PercentageToStarConverter}}"/>
                                <ColumnDefinition Width="{Binding DataContext.SuccessAllocationPercentage, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource PercentageToStarConverter}}"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#d13438" Grid.Column="0"/>
                            <Border Background="#107c10" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
                <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Text="{Binding StatusMessage}"/>
            </StackPanel>

            <!-- Results Section -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,20"
                        Visibility="{Binding ShowResults, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border BorderBrush="#d0d0d0" BorderThickness="1" CornerRadius="4" Padding="5" Background="#f9f9f9" Height="Auto">
                    <StackPanel Orientation="Vertical">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="Processing Results"/></TextBlock>
                        <TextBlock FontSize="11" Foreground="#666"><Run FontWeight="Bold" Text="Allocations Submitted: "/><Run Text="{Binding AllocationsSubmittedCount}"/></TextBlock>
                        <TextBlock FontSize="11" Foreground="#666"><Run FontWeight="Bold" Text="Allocations Processed: "/><Run Text="{Binding ProcessedTradesCount}"/></TextBlock>
                        <TextBlock FontSize="11" Foreground="#666"><Run FontWeight="Bold" Text="Allocations Sent:"/><Run Text=" "/><Run Text="{Binding SentAllocationsCount}"/></TextBlock>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                           <!--  <StackPanel Grid.Column="1" Orientation="Vertical">
                               <TextBlock FontSize="11" Foreground="#107c10" TextWrapping="Wrap" Text="{Binding ResultSuccessMessage}" Visibility="{Binding ResultSuccessMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                                <TextBlock FontSize="11" Foreground="#d13438" TextWrapping="Wrap" Text="{Binding ResultFailureMessage}" Visibility="{Binding ResultFailureMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </StackPanel> -->
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- FIX Messages Display -->
                <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="Generated FIX Messages"/></TextBlock>
                    <ListBox ItemsSource="{Binding GeneratedMessages}" Height="200" FontSize="11" SelectionChanged="ListBox_SelectionChanged" av:ItemsSource="{av:SampleData ItemCount=5}" SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1" Background="#f9f9f9" HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="&#xE8C8;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Width="24"
                                                Height="24"
                                                Margin="0,2,10,0"
                                                ToolTip="Copy FIX message"
                                                Tag="{Binding RawFix}"
                                                Click="CopyFixMessage_Click"
                                                Padding="0"/>
                                        <StackPanel Grid.Column="1" Orientation="Vertical">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontWeight="SemiBold" Foreground="#333" Text="{Binding AllocId}"/>
                                                <TextBlock Grid.Column="1" Foreground="#666" Margin="15,0,0,0"><Run Text="Side: "/><Run Text="{Binding Side, Converter={StaticResource SideDisplayConverter}}" FontWeight="SemiBold"/></TextBlock>
                                                <TextBlock Grid.Column="2" Foreground="#666" Margin="15,0,0,0"><Run Text="Symbol: "/><Run Text="{Binding Symbol}" FontWeight="SemiBold"/></TextBlock>
                                                <TextBlock Grid.Column="3" Foreground="#666" Margin="15,0,0,0"><Run Text="Merged Allocations: "/><Run Text="{Binding TradeCount}" FontWeight="SemiBold"/></TextBlock>
                                                <TextBlock Grid.Column="4" HorizontalAlignment="Left" Foreground="#666" FontSize="11" Margin="10,0,0,0"><Run Text="{Binding Status}" FontWeight="Bold"/></TextBlock>
                                            </Grid>
                                            <TextBlock TextWrapping="WrapWithOverflow" Foreground="#FF160101" FontSize="11" FontFamily="Courier New" Background="{x:Null}" FontWeight="Bold" Width="NaN" Margin="0,1,0,1"><Run Text="{Binding RawFix}"/></TextBlock>
         
                                            <TextBlock Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" 
                                                       Foreground="#d13438" FontSize="9" Text="{Binding ErrorMessage}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
