<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="FixFlow.TradeAllocBridge.WPF.Views.MapEditorView"
             Background="#ffffff">
    <UserControl.Resources>
        <BitmapImage x:Key="AddIconBitmap" UriSource="/Resources/Icons/Add.png"/>
        <BitmapImage x:Key="UpdateIconBitmap" UriSource="/Resources/Icons/Update.png"/>
        <BitmapImage x:Key="DeleteIconBitmap" UriSource="/Resources/Icons/Delete.png"/>
        <FormatConvertedBitmap x:Key="AddIconBitmapGray" Source="{StaticResource AddIconBitmap}" DestinationFormat="Gray32Float"/>
        <FormatConvertedBitmap x:Key="UpdateIconBitmapGray" Source="{StaticResource UpdateIconBitmap}" DestinationFormat="Gray32Float"/>
        <FormatConvertedBitmap x:Key="DeleteIconBitmapGray" Source="{StaticResource DeleteIconBitmap}" DestinationFormat="Gray32Float"/>
        <Style x:Key="FieldIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" BorderThickness="0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldIconImage" TargetType="Image">
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>
        <Style x:Key="TagLevelBadge" TargetType="Border">
            <Setter Property="Background" Value="#e6eef6"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#c6d6ea"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Value, Converter={StaticResource TagLevelConverter}}" Value="NoAllocs">
                    <Setter Property="Background" Value="#fff4e5"/>
                    <Setter Property="BorderBrush" Value="#f3caa2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Value, Converter={StaticResource TagLevelConverter}}" Value="Unknown">
                    <Setter Property="Background" Value="#f3f3f3"/>
                    <Setter Property="BorderBrush" Value="#d5d5d5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid ShowGridLines="False">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Mapping List -->
        <Border Padding="15" Background="#f5f5f5" BorderBrush="#d0d0d0" BorderThickness="0,0,1,0" HorizontalAlignment="Center" Width="250">
            <StackPanel Orientation="Vertical">
                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"><Run Text="Client Mappings"/></TextBlock>

                <ListBox x:Name="MappingListBox"
                     ItemsSource="{Binding AvailableMappings}"
                     SelectedItem="{Binding SelectedMapping, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11"
                     Height="200"
                     Margin="0,0,0,10"/>

                <StackPanel>
                    <Button Content="&#x2795; New" Command="{Binding NewMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#005a9e" Height="32" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Button Content="&#x270F;&#xFE0F; Edit" Command="{Binding EditMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#FF21B1C9" Height="32" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Button Content="&#x2705; Validate" Command="{Binding ValidateMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#FF2BB61B" Height="32" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Button Content="&#x1F4E8; Automate"
                            Command="{Binding DeployMappingCommand}"
                            ToolTip="{Binding DeployTooltip}"
                            ToolTipService.ShowOnDisabled="True"
                            Style="{StaticResource PrimaryButton}"
                            Background="#FF699170"
                            Height="32"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8"/>
                    <Button Content="&#x1F5D1;&#xFE0F; Delete" Command="{Binding DeleteMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#FFEB4634" Height="32" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Right Panel: Mapping Details -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <Border Padding="20,10,20,9" Margin="0,0,0,-1">
                    <StackPanel Orientation="Vertical">
                    <!-- Status Message -->
                    <TextBlock FontSize="12" Foreground="#666" TextWrapping="Wrap" Text="{Binding StatusMessage}" Margin="0,0,0,5"/>

                    <!-- Incoming folder path (visible after staging) --><!--
                    <TextBlock FontSize="11" Foreground="#444" TextWrapping="Wrap" Text="{Binding IncomingFolderPath}" Margin="0,0,0,10"
                               Visibility="{Binding IncomingFolderPath, Converter={StaticResource StringToVisibilityConverter}}"/>-->

                    <!-- Client Identity Section -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,5" IsEnabled="{Binding IsEditing}"
                                Visibility="{Binding ShowMappingDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="Client Identity"/></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Organization ID:" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Padding="8" FontSize="11" Margin="10,8,0,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Sender Domain:" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SenderDomain, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Padding="8" FontSize="11" Margin="10,8,0,0"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding SenderDomainWarning}"
                                       FontSize="10"
                                       Foreground="#b45309"
                                       Margin="10,2,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding SenderDomainWarning, Converter={StaticResource StringToVisibilityConverter}}"/>
                            <!-- OnBehalfOfCompID (Tag 115) -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="FIX ID (Tag 115):" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="10,8,0,0" Text="{Binding OnBehalfOfCompId, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Padding="8" FontSize="11"/>

                        </Grid>
                    </StackPanel>

                    <!-- FIX Predefined Fields Section -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,8" IsEnabled="{Binding IsEditing}"/>

                    <!-- Field Mappings Section -->
                    <StackPanel Orientation="Vertical" Margin="0,5,0,1"
                                Visibility="{Binding ShowMappingDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="SemiBold" Foreground="#333" Text="Trade Allocation Field Mappings"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ListBox Grid.Column="0"
                                     ItemsSource="{Binding FieldMappings}"
                                     SelectedItem="{Binding SelectedFieldMapping}"
                                     Height="200"
                                     FontSize="11" av:ItemsSource="{av:SampleData ItemCount=5}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" MinWidth="220">
                                                    <Border Style="{StaticResource TagLevelBadge}">
                                                        <TextBlock FontSize="9"
                                                           Foreground="#445266"
                                                           Text="{Binding Value, Converter={StaticResource TagLevelConverter}}"/>
                                                    </Border>
                                                    <TextBlock Foreground="#666"
                                                               Text="{Binding Value, Converter={StaticResource TagDisplayConverter}}" Margin="10,0,0,0"/>
                                                    
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold" Foreground="#333" Margin="10,0,0,0" Text="{Binding Key, Mode=OneWay}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Column="1"
                                        Orientation="Vertical"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button Command="{Binding MoveFieldUpCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="26"
                                        Width="30"
                                        FontSize="12"
                                        Padding="0"
                                        Margin="0,0,0,6"
                                        ToolTip="Move up" Background="Gray">
                                    ▲
                                </Button>
                                <Button Command="{Binding MoveFieldDownCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="26"
                                        Width="30"
                                        FontSize="12"
                                        Padding="0"
                                        ToolTip="Move down" Background="Gray">
                                    ▼
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Add/Edit/Delete Field Section (only when editing) -->
                        <Border BorderBrush="#d0d0d0" BorderThickness="1" Padding="5" Background="#f9f9f9" Margin="0,0,38,11" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Vertical">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333" Width="450" Text="Add / Edit Field" HorizontalAlignment="Left"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0" Width="146" Grid.Column="0">
                                        <Button ToolTip="Add"
                                                Command="{Binding AddFieldCommand}"
                                                Style="{StaticResource FieldIconButton}"
                                                Width="44"
                                                Height="44"
                                                Padding="6"
                                                Margin="0,0,8,0">
                                            <Image Height="34" Width="34">
                                                <Image.Style>
                                                    <Style TargetType="Image" BasedOn="{StaticResource FieldIconImage}">
                                                        <Setter Property="Source" Value="{StaticResource AddIconBitmap}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Source" Value="{StaticResource AddIconBitmapGray}"/>
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Button>
                                        <Button ToolTip="Update"
                                                Command="{Binding UpdateFieldCommand}"
                                                Style="{StaticResource FieldIconButton}"
                                                Width="44"
                                                Height="44"
                                                Padding="6"
                                                IsEnabled="{Binding CanUpdateField}"
                                                Margin="0,0,8,0">
                                            <Image Height="34" Width="34">
                                                <Image.Style>
                                                    <Style TargetType="Image" BasedOn="{StaticResource FieldIconImage}">
                                                        <Setter Property="Source" Value="{StaticResource UpdateIconBitmap}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Source" Value="{StaticResource UpdateIconBitmapGray}"/>
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Button>
                                        <Button ToolTip="Delete"
                                                Command="{Binding RemoveFieldCommand}"
                                                Style="{StaticResource FieldIconButton}"
                                                Width="44"
                                                Height="44"
                                                Padding="6"
                                                Margin="0,0,0,0"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Image RenderTransformOrigin="0.95,0.49" HorizontalAlignment="Left">
                                                <Image.Style>
                                                    <Style TargetType="Image" BasedOn="{StaticResource FieldIconImage}">
                                                        <Setter Property="Source" Value="{StaticResource DeleteIconBitmap}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                                                                <Setter Property="Source" Value="{StaticResource DeleteIconBitmapGray}"/>
                                                                <Setter Property="Opacity" Value="0.7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical" RenderTransformOrigin="0.5,0.5" Margin="13,0,82,-1" Grid.Column="1">
                                        <StackPanel.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform AngleY="-0.355"/>
                                                <RotateTransform/>
                                                <TranslateTransform Y="0.527"/>
                                            </TransformGroup>
                                        </StackPanel.RenderTransform>
                                        <TextBlock FontSize="10" Foreground="#555" Width="Auto"><Run Text="Tag ID"/></TextBlock>
                                        <Grid>
                                            <TextBox x:Name="TagIdTextBox"
                                                     Text="{Binding NewFieldTagInput, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="9"
                                                     FontSize="11"
                                                     HorizontalAlignment="Left"
                                                     MinWidth="50"/>
                                            <Popup PlacementTarget="{Binding ElementName=TagIdTextBox}"
                                                   Placement="Bottom"
                                                   AllowsTransparency="True"
                                                   StaysOpen="False"
                                                   IsOpen="{Binding IsFixFieldSuggestionOpen}">
                                                <Border Background="#ffffff"
                                                        BorderBrush="#cfcfcf"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="4"
                                                        MaxWidth="280">
                                                    <ListBox ItemsSource="{Binding FixFieldSuggestions}"
                                                             SelectedItem="{Binding SelectedFixFieldSuggestion, Mode=TwoWay}"
                                                             DisplayMemberPath="Display"
                                                             MinWidth="220"
                                                             MaxHeight="180"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Vertical" Margin="-70,0,0,0">
                                        <TextBlock FontSize="10"
                                                   Foreground="#555"
                                                   Text="Column Name or Position"
                                                   ToolTip="Use a number (1, 2, 3...) to indicate column position for headless spreadsheets."/>
                                        <TextBox Text="{Binding NewFieldName, UpdateSourceTrigger=PropertyChanged}" Padding="9" FontSize="11" HorizontalAlignment="Left" MinWidth="200"/>
                                    </StackPanel>
                                </Grid>
                                <Border Margin="0,10,0,0"
                                        Padding="8"
                                        Background="#fff8eb"
                                        BorderBrush="#f0c36d"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Visibility="{Binding DependencyWarningMessage, Converter={StaticResource StringToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock FontSize="10"
                                                   Foreground="#7a4b00"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding DependencyWarningMessage}"/>
                                        <ItemsControl ItemsSource="{Binding DependencyDefaults}" Margin="0,6,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Width="200"
                                                                   FontSize="10"
                                                                   Foreground="#555"
                                                                   Text="{Binding Display}"/>
                                                        <TextBox Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                                 MinWidth="160"
                                                                 Padding="6"
                                                                 FontSize="10"
                                                                 Margin="8,0,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Required tags warning -->
                    <Border Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock FontSize="11"
                                   Foreground="#d13438"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"
                                   Text="{Binding MissingRequiredTagsMessage}"
                                   Visibility="{Binding MissingRequiredTagsMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0" Height="37">
                        <Button Content="Save" 
                            Command="{Binding SaveMappingCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#107c10"
                            Height="36"
                            Margin="2,0,10,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" FontWeight="Bold"/>
                        <Button Content="Cancel" 
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#FFE83C41"
                            Height="36"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" FontWeight="Bold"/>
                    </StackPanel>

                </StackPanel>
                </Border>
            </ScrollViewer>
            <!-- Read-only metadata (sticky footer) -->
            <Border Grid.Row="1" Padding="20,0,20,12" Background="#ffffff">
                <StackPanel Orientation="Vertical">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ShowMappingDetails}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock FontSize="12" Foreground="#666" FontWeight="SemiBold">
                        <Run Text="Date Created: "/>
                        <Run Text="{Binding DateCreated}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#666" FontWeight="SemiBold">
                        <Run Text="Date Validated: "/>
                        <Run Text="{Binding DateValidated}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#666" FontWeight="SemiBold">
                        <Run Text="Date Modified: "/>
                        <Run Text="{Binding DateModified}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#666" FontWeight="SemiBold">
                        <Run Text="Email Automation Status: "/>
                        <!--<Run Text="{Binding EmailAutomationStatus}"/>-->
                        <Run Text="Disabled"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

