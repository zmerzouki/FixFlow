<Window x:Class="FixFlow.TradeAllocBridge.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FixFlow.TradeAllocBridge.WPF.Views"
        Title="Trade Allocation Bridge"
        Width="1000"
        Height="750"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Resources/FxF.ico"
        Background="#ffffff">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="20" Background="#f0f0f0" BorderBrush="#d0d0d0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Vertical">
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#333">Trade Allocation Bridge</TextBlock>
                <TextBlock FontSize="12" Foreground="#666" Margin="0,4,0,0">Process trade allocations and manage client mappings</TextBlock>
            </StackPanel>
        </Border>

        <!-- Main Content: Tabbed Interface -->
        <TabControl Grid.Row="1">
            <!-- Direct Ingestion Tab -->
            <TabItem Header="📤 Direct Ingestion" Padding="15,10">
                <local:DirectIngestionView VerticalAlignment="Top"/>
            </TabItem>

            <!-- Map Management Tab -->
            <TabItem Header="🗺️ Map Management" Padding="15,10">
                <local:MapEditorView/>
            </TabItem>

            <!-- Message History Tab -->
            <TabItem Header="📋 Message History" Padding="15,10">
                <local:MessageHistoryView/>
            </TabItem>
            <!-- Settings Tab -->
            <TabItem Header="⚙️ Global Settings" Padding="15,10">
                <local:SettingsView/>
            </TabItem>
        </TabControl>

        <!-- Footer -->
    </Grid>
</Window>
