<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="RJF.TradeAllocBridge.WPF.Views.MapEditorView"
             Background="#ffffff">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="250"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Left Panel: Mapping List -->
    <Border Grid.Column="0" Padding="15" Background="#f5f5f5" BorderBrush="#d0d0d0" BorderThickness="0,0,1,0">
      <StackPanel Orientation="Vertical">
        <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"><Run Text="Client Mappings"/></TextBlock>

        <ListBox x:Name="MappingListBox"
                     ItemsSource="{Binding AvailableMappings}"
                     SelectedItem="{Binding SelectedMapping, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="11"
                     Height="200"
                     Margin="0,0,0,10"/>

        <StackPanel>
          <Button Content="➕ New" Command="{Binding NewMappingCommand}" Style="{StaticResource PrimaryButton}" Height="32" FontSize="11" Margin="0,0,0,8"/>
          <Button Content="✏️ Edit" Command="{Binding EditMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#107c10" Height="32" FontSize="11" Margin="0,0,0,8"/>
          <Button Content="🚀 Deploy" Command="{Binding DeployMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#7fba00" Height="32" FontSize="11" Margin="0,0,0,8"/>
          <Button Content="🗑️ Delete" Command="{Binding DeleteMappingCommand}" Style="{StaticResource PrimaryButton}" Background="#d13438" Height="32" FontSize="11"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Right Panel: Mapping Details -->
    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <Border Padding="20">
        <StackPanel Orientation="Vertical">
          <!-- Status Message -->
          <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Text="{Binding StatusMessage}" Margin="0,0,0,15"/>

          <!-- Client Identity Section -->
          <StackPanel Orientation="Vertical" Margin="0,0,0,15" IsEnabled="{Binding IsEditing}">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="Client Identity"/></TextBlock>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="Client ID:" VerticalAlignment="Center" FontSize="11"/>
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="11" Margin="10,0,0,0" SelectionOpacity="1"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Sender Domain:" VerticalAlignment="Center" FontSize="11" Margin="0,8,0,0"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SenderDomain, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="11" Margin="10,8,0,0"/>
            </Grid>
          </StackPanel>

          <!-- FIX Predefined Fields Section -->
          <StackPanel Orientation="Vertical" Margin="0,0,0,15" IsEnabled="{Binding IsEditing}">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="FIX Predefined Fields"/></TextBlock>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <!-- SenderCompID (Tag 49) -->
              <TextBlock Grid.Row="0" Grid.Column="0" Text="SenderCompID (49):" VerticalAlignment="Center" FontSize="11"/>
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SenderCompId, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="11" Margin="10,0,0,0"/>

              <!-- TargetCompID (Tag 56) -->
              <TextBlock Grid.Row="1" Grid.Column="0" Text="TargetCompID (56):" VerticalAlignment="Center" FontSize="11" Margin="0,8,0,0"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TargetCompId, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="11" Margin="10,8,0,0"/>
            </Grid>
          </StackPanel>

          <!-- Field Mappings Section -->
          <StackPanel Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#333"><Run Text="Trade Allocation Field Mappings ("/><Run Text="{Binding FieldMappings.Count, Mode=OneWay}"/><Run Text=" fields)"/></TextBlock>

            <ListBox ItemsSource="{Binding FieldMappings}"
                             SelectedItem="{Binding SelectedFieldMapping}"
                             Height="200"
                             FontSize="11" av:ItemsSource="{av:SampleData ItemCount=5}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Padding="8" BorderBrush="#e0e0e0" BorderThickness="0,0,0,1">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" FontWeight="SemiBold" Foreground="#333" MinWidth="120" Text="{Binding Key, Mode=OneWay}"/>
                      <TextBlock Grid.Column="1" Foreground="#666" Margin="10,0,0,0"><Run Text="→ Tag "/><Run Text=" "/><Run Text="{Binding Value, Mode=OneWay}" FontWeight="SemiBold"/></TextBlock>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <!-- Add Field Section (only when editing) -->
            <Border BorderBrush="#d0d0d0" BorderThickness="1" Padding="12" Background="#f9f9f9" Margin="0,0,0,10" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
              <StackPanel Orientation="Vertical">
                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#333"><Run Text="Add New Field (Excel Column to Tag Value)"/></TextBlock>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="140"/>
                  </Grid.ColumnDefinitions>

                  <TextBox Grid.Column="0" Text="{Binding NewFieldName, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="11"/>
                  <TextBox Grid.Column="1" Text="{Binding NewFieldTag, UpdateSourceTrigger=PropertyChanged}" Padding="8" FontSize="11" Margin="10,0,0,0"/>
                  <Button Grid.Column="2" Content="➕ Add" Command="{Binding AddFieldCommand}" Style="{StaticResource PrimaryButton}" Height="28" Margin="10,0,0,0" FontSize="10"/>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Remove Field Button -->
            <Button Content="🗑️ Remove Selected Field" 
                            Command="{Binding RemoveFieldCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#d13438"
                            Height="32"
                            FontSize="11"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
          </StackPanel>

          <!-- Action Buttons -->
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="💾 Save" 
                            Command="{Binding SaveMappingCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#107c10"
                            Height="36"
                            Margin="0,0,10,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Cancel" 
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="#d13438"
                            Height="36"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>
